{
  "hosting": {
    "public": "_deploy",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/.git"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}